## 4. app.component.html (dark layout + carousels)

```html
<!-- src/app/app.component.html -->
<div class="app-root">
  <!-- Header -->
  <header class="app-header">
    <div class="logo">YourName<span>.</span></div>
    <nav class="nav-links">
      <a href="#hero">Home</a>
      <a href="#photography">Photography</a>
      <a href="#videography">Videography</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <!-- Hero Carousel -->
  <section id="hero" class="hero-section">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Visual stories in motion & stills</h1>
        <p>
          I create cinematic wedding films, bold portraits, and atmospheric
          visuals for brands and artists.
        </p>
        <a href="#contact" class="btn-primary">Book a shoot</a>
      </div>

      <div class="hero-carousel">
        <div class="carousel-window">
          <div
            class="carousel-slide"
            *ngFor="let slide of heroSlides; let i = index"
            [class.active]="i === heroIndex"
          >
            <ng-container [ngSwitch]="slide.type">
              <img
                *ngSwitchCase="'photo'"
                [src]="slide.src"
                [alt]="slide.title"
              />
              <video
                *ngSwitchCase="'video'"
                [src]="slide.src"
                muted
                autoplay
                loop
              ></video>
            </ng-container>
            <div class="slide-overlay">
              <h3>{{ slide.title }}</h3>
              <p>{{ slide.description }}</p>
            </div>
          </div>
        </div>
        <button class="nav-btn left" (click)="prevHero()">‹</button>
        <button class="nav-btn right" (click)="nextHero()">›</button>
        <div class="dots">
          <span
            *ngFor="let slide of heroSlides; let i = index"
            [class.active]="i === heroIndex"
            (click)="heroIndex = i"
          ></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Photography Carousel -->
  <section id="photography" class="section">
    <div class="section-header">
      <h2>Photography</h2>
      <p>Curated selections from weddings, portraits, and editorial work.</p>
    </div>

    <div class="carousel-block">
      <button class="nav-btn left" (click)="prevPhoto()">‹</button>

      <div class="carousel-window">
        <div
          class="carousel-slide single"
          *ngFor="let item of photographyItems; let i = index"
          [class.active]="i === photoIndex"
        >
          <img [src]="item.src" [alt]="item.title" />
          <div class="slide-overlay bottom">
            <h3>{{ item.title }}</h3>
          </div>
        </div>
      </div>

      <button class="nav-btn right" (click)="nextPhoto()">›</button>
    </div>

    <div class="thumb-row">
      <div
        class="thumb"
        *ngFor="let item of photographyItems; let i = index"
        [class.active]="i === photoIndex"
        (click)="photoIndex = i"
      >
        <img [src]="item.thumb || item.src" [alt]="item.title" />
      </div>
    </div>
  </section>

  <!-- Videography Carousel -->
  <section id="videography" class="section">
    <div class="section-header">
      <h2>Videography</h2>
      <p>Short teasers, music videos, and event films.</p>
    </div>

    <div class="carousel-block">
      <button class="nav-btn left" (click)="prevVideo()">‹</button>

      <div class="carousel-window">
        <div
          class="carousel-slide single"
          *ngFor="let item of videographyItems; let i = index"
          [class.active]="i === videoIndex"
        >
          <video [src]="item.src" controls></video>
          <div class="slide-overlay bottom">
            <h3>{{ item.title }}</h3>
          </div>
        </div>
      </div>

      <button class="nav-btn right" (click)="nextVideo()">›</button>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section about-section">
    <div class="about-text">
      <h2>About</h2>
      <p>
        I am a photographer and videographer focused on cinematic, clean visuals
        with a love for low-light and minimal compositions.
      </p>
      <p>
        I work with couples, brands, and independent artists to build visual
        stories that feel honest and immersive.
      </p>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section contact-section">
    <div class="section-header">
      <h2>Contact</h2>
      <p>Tell me about your project, event, or idea.</p>
    </div>
    <form class="contact-form">
      <div class="row">
        <input type="text" placeholder="Name" />
        <input type="email" placeholder="Email" />
      </div>
      <div class="row">
        <input type="text" placeholder="Project type (wedding, brand, etc.)" />
      </div>
      <div class="row">
        <textarea rows="4" placeholder="Describe what you have in mind"></textarea>
      </div>
      <button type="submit" class="btn-primary">Send inquiry</button>
    </form>
  </section>

  <footer class="footer">
    <span>© {{ new Date().getFullYear() }} Your Name. All rights reserved.</span>
  </footer>
</div>
